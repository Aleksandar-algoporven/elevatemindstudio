{
  "name": "elevatemindstudio",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/web",
    "lint": "npm run lint --workspace apps/web",
    "typecheck": "npm run typecheck --workspace apps/web",
    "test:api": "cd apps/api && python3 -m pytest",
    "check": "npm run typecheck && npm run lint && npm run test:api"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
